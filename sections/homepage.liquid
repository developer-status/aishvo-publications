  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const header = document.querySelector('.hp-header');
      const menuButton = document.querySelector('.hp-header__menu-button');
      const nav = document.querySelector('.hp-nav');

      if (menuButton && header && nav) {
        menuButton.addEventListener('click', function() {
          header.classList.toggle('hp-header--open');
          const expanded = header.classList.contains('hp-header--open');
          menuButton.setAttribute('aria-expanded', expanded);
        });
      }
    });
  </script>
