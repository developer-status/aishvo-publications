    </div>

    <div class="hp-section__footer">
      <a href="#books" class="hp-button hp-button--outline">View all books →</a>
    </div>
  </section>

  <section class="hp-section hp-bundle" id="bundle">
    <div class="page-width hp-bundle__inner">
