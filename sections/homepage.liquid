          <span class="hp-product-card__age">2–5 yrs</span>
          <span class="hp-product-card__emoji">123</span>
        </div>
        <div class="hp-product-card__body">
          <h3>My First 123 Book</h3>
          <p>Aishvo Publications</p>
          <div class="hp-product-card__footer">
            <span class="hp-product-card__price">₹199</span>
            <span class="hp-product-card__mrp">₹250</span>
            <button class="hp-button hp-button--mini">Add +</button>
          </div>
        </div>
      </article>

      <article class="hp-product-card hp-product-card--green-light">
        <div class="hp-product-card__media">
          <span class="hp-product-card__badge">Bestseller</span>
          <span class="hp-product-card__age">3–7 yrs</span>
          <span class="hp-product-card__emoji">🥕</span>
        </div>
        <div class="hp-product-card__body">
          <h3>Fruits & Veggies Coloring</h3>
          <p>Aishvo Publications</p>
          <div class="hp-product-card__footer">
            <span class="hp-product-card__price">₹149</span>
            <span class="hp-product-card__mrp">₹199</span>
            <button class="hp-button hp-button--mini">Add +</button>
          </div>
        </div>
