{{ 'homepage.css' | asset_url | stylesheet_tag }}

<section class="hp-homepage" aria-label="Aishvo Publications homepage">
  <div class="hp-announcement-bar">
    <div class="page-width hp-announcement-bar__content">
      <p>
        Free shipping on orders above <span>₹499</span> ✦ New books every month ✦ <span>Kids age 1–10 years</span>
      </p>
    </div>
  </div>

  <header class="hp-header" role="banner">
    <div class="page-width hp-header__inner">
      <div class="hp-header__logo-wrap">
        <a href="{{ routes.root_url }}" class="hp-logo-link" aria-label="Aishvo Publications home">
          <span class="hp-logo-icon" aria-hidden="true">
            <span class="hp-logo-icon__book hp-logo-icon__book--left">
              <span class="hp-logo-icon__spine"></span>
            </span>
            <span class="hp-logo-icon__book hp-logo-icon__book--right">
              <span class="hp-logo-icon__spine hp-logo-icon__spine--purple"></span>
            </span>
          </span>
          <span class="hp-logo-copy">
            <span class="hp-logo-copy__brand">Aishvo</span>
            <span class="hp-logo-copy__company">Publications</span>
          </span>
          <span class="hp-logo-copy__tagline">WHERE LITTLE STORIES BEGIN</span>
        </a>
      </div>

      <nav class="hp-nav" aria-label="Primary navigation">
        <a href="#home">Home</a>
        <a href="#books">Books</a>
        <a href="#age-groups">Age groups</a>
        <a href="#toys">Toys</a>
        <a href="#about">About us</a>
      </nav>

      <div class="hp-header__actions">
        <button class="hp-button hp-button--small" type="button">Shop now</button>
        <button class="hp-icon-button" type="button" aria-label="Search">🔍</button>
        <button class="hp-icon-button" type="button" aria-label="Wishlist">❤</button>
        <a href="/cart" class="hp-icon-button" aria-label="Cart">🛍</a>
      </div>

      <button class="hp-header__menu-button" type="button" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <section class="hp-hero" id="home">
    <div class="hp-hero__inner page-width">
      <div class="hp-hero__copy">
        <span class="hp-hero__badge">✦ New arrivals for 2025</span>
        <h1>Books that make <span class="hp-highlight">little minds</span> shine</h1>
        <p>Colorful, joyful books crafted with love for curious kids aged 1 to 10 years. Published in India by Aishvo Publications.</p>

        <div class="hp-hero__buttons">
          <a href="#books" class="hp-button hp-button--primary">Shop all books</a>
          <a href="#age-groups" class="hp-button hp-button--secondary">Browse by age</a>
        </div>

        <div class="hp-hero__stats">
          <div class="hp-stat">
            <span class="hp-stat__value">50+</span>
            <span class="hp-stat__label">Happy kids</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat__value">5</span>
            <span class="hp-stat__label">Book titles</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat__value">4</span>
            <span class="hp-stat__label">Platforms</span>
          </div>
          <div class="hp-stat">
            <span class="hp-stat__value">★ 4.9</span>
            <span class="hp-stat__label">Parent rating</span>
          </div>
        </div>
      </div>

      <div class="hp-hero__visual" aria-hidden="true">
        <div class="hp-book-stack">
          <div class="hp-book hp-book--1">🔤</div>
          <div class="hp-book hp-book--2">🎨</div>
          <div class="hp-book hp-book--3">🦁</div>
          <div class="hp-book hp-book--4">🧩</div>
        </div>
      </div>
    </div>
  </section>

  <section class="hp-trust" aria-label="Trust benefits">
    <div class="page-width hp-trust__inner">
      <div class="hp-trust__item"><span class="hp-trust__icon">🚚</span>Free delivery above ₹499</div>
      <div class="hp-trust__item"><span class="hp-trust__icon">🔁</span>Easy 7-day returns</div>
      <div class="hp-trust__item"><span class="hp-trust__icon">🛡</span>BIS certified safe</div>
      <div class="hp-trust__item"><span class="hp-trust__icon">🇮🇳</span>Made in India</div>
      <div class="hp-trust__item"><span class="hp-trust__icon">💳</span>Secure payments</div>
    </div>
  </section>

  <section class="hp-section hp-age" id="age-groups">
    <div class="page-width hp-section__header">
      <span class="hp-label-pill">Shop by age</span>
      <h2>Find the perfect book for your child</h2>
      <p>Every book carefully designed for the right age — so your child learns and grows at their own pace.</p>
    </div>

