      <a href="#books" class="hp-card hp-card--age hp-card--soft">
        <span class="hp-card__emoji">👶</span>
        <span class="hp-card__title">Ages 1–2</span>
        <span class="hp-card__subtitle">Board books</span>
        <span class="hp-card__arrow">→</span>
      </a>
      <a href="#books" class="hp-card hp-card--age hp-card--purple">
        <span class="hp-card__emoji">🧒</span>
        <span class="hp-card__title">Ages 3–5</span>
        <span class="hp-card__subtitle">Picture books</span>
        <span class="hp-card__arrow">→</span>
      </a>
      <a href="#books" class="hp-card hp-card--age hp-card--green">
        <span class="hp-card__emoji">📚</span>
        <span class="hp-card__title">Ages 6–8</span>
        <span class="hp-card__subtitle">Activity books</span>
        <span class="hp-card__arrow">→</span>
      </a>
      <a href="#books" class="hp-card hp-card--age hp-card--teal">
        <span class="hp-card__emoji">🎓</span>
        <span class="hp-card__title">Ages 9–10</span>
        <span class="hp-card__subtitle">Reader books</span>
        <span class="hp-card__arrow">→</span>
      </a>
    </div>
  </section>

